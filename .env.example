# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── AWS ───────────────────────────────────────────────────────────────────────
# Omit ACCESS_KEY_ID / SECRET_ACCESS_KEY when running on EC2/EB with an IAM role
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── S3 ────────────────────────────────────────────────────────────────────────
# Bucket that holds the pre-uploaded audio files (shared with ProlificAnnotationApp)
S3_BUCKET=your-audio-bucket-name

# ── DynamoDB table names ──────────────────────────────────────────────────────
# CALIBER-full SHARES these tables with ProlificAnnotationApp:
TABLE_ADMINS=paa-admins
TABLE_SONA_ITEMS=paa-sona-items
TABLE_LLM_GRADES=paa-llm-grades

# CALIBER-full uses its OWN tables for everything experiment-scoped:
TABLE_CONFIG=caliber-config
TABLE_ANNOTATORS=caliber-annotators
TABLE_ANNOTATIONS=caliber-annotations
TABLE_TELEMETRY=caliber-telemetry

# ── Pool counter column on shared paa-sona-items meta rows ────────────────────
# CALIBER's draws/sweeps/resets only touch THIS column; never touches paa's.
POOL_COUNTER_COLUMN=assigned_count_caliber

# ── LLM source for highlight/score hydration ──────────────────────────────────
# Filters eligibility to sonas that have grades from this model in paa-llm-grades,
# and is the model whose phrases/scores hydrate the grading UI.
CALIBER_LLM_MODEL=opus4.8max

# ── Bootstrap super-admin (idempotent — safe to share with ProlificAnnotationApp) ─
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me-immediately

# ── CORS (leave * for development; set to your EB/CloudFront domain in prod) ──
CORS_ORIGIN=*
